import { useState, useEffect } from "react";
import "./App.css";
import { AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer } from "recharts";

const API_BASE_URL = "http://localhost:8000";

// SVG Icons
const GlobeIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0M2.04 4.326c.325 1.329 2.532 2.54 3.717 3.19.48.263.793.434.743.484q-.121.12-.242.234c-.416.396-.787.749-.758 1.266.035.634.618.824 1.214 1.017.577.188 1.168.38 1.286.983.082.417-.075.988-.22 1.52-.215.782-.406 1.48.22 1.48 1.5-.5 3.798-3.186 4-5 .138-1.243-2-2-3.5-2.5-.478-.16-.755.081-.99.284-.172.15-.322.279-.51.216-.445-.148-2.5-2-1.5-2.5.78-.39.952-.171 1.227.182.078.099.163.208.273.318.609.304.662-.132.723-.633.039-.322.081-.671.277-.867.434-.434 1.265-.791 2.028-1.12.712-.306 1.365-.587 1.579-.88A7 7 0 1 1 2.04 4.327Z"/>
  </svg>
);

const TrendUpIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path fillRule="evenodd" d="M0 0h1v15h15v1H0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5"/>
  </svg>
);

const ChartIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path d="M1 11a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1zm5-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1z"/>
  </svg>
);

const MapIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path fillRule="evenodd" d="m4.502 1 2.596 2.596a.5.5 0 0 0 .706 0l2.596-2.596a.5.5 0 0 1 .707 0l2.596 2.596a.5.5 0 0 0 .707 0l2.596-2.596a.5.5 0 0 1 .707.707L14.207 4.5l2.596 2.596a.5.5 0 1 1-.707.707L13.5 5.207l-2.596 2.596a.5.5 0 0 1-.707 0L7.5 5.207 4.904 7.803a.5.5 0 1 1-.707-.707L6.793 4.5 4.207 1.914a.5.5 0 0 1 .707-.707z" clipRule="evenodd"/>
  </svg>
);

const AlertIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0l-5.5 9.428c-.5.899.233 2.042 1.24 2.042h11.04c1.007 0 1.74-1.143 1.24-2.042L8.982 1.566zM8 5a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 5zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
  </svg>
);

const HeartIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path d="m8 2.748-.717-.737C5.6.281 2.514.293 1.035 3.071.063 5.108.057 7.169.627 9.1.67 9.23.69 9.47.69 10c0 .5.1 1.8 1 2.8.5.6 1.3 1.7 2.5 3 1.5 1.7 3 3.5 5 5.5 2-2 3.5-3.8 5-5.5 1.2-1.3 2-2.4 2.5-3 .9-1 1-2.3 1-2.8 0-.53-.02-.77-.063-.9-.568-1.931-.574-4.005.027-5.91.552-1.59 1.425-2.257 2.182-2.257.52 0 1.019.284 1.574.996l1.324 1.407-1.03 1.03c-.524.523-.927 1.079-.927 2.026 0 .55.458 1.033 1.033 1.033h.066c.546 0 1.033-.487 1.033-1.033 0-1.065.27-2.055.645-2.978.405-.926.935-1.800 1.831-2.058.667-.19 1.222-.066 1.666.237.444.305.722.77.722 1.271 0 .552-.458 1.033-1.033 1.033h-.066c-.546 0-1.033.487-1.033 1.033 0 1.065-.27 2.055-.645 2.978-.405.926-.935 1.800-1.831 2.058-.667.19-1.222.066-1.666-.237a1.72 1.72 0 0 1-.704-1.066l-1.323-1.406 1.03-1.03c.524-.523.927-1.079.927-2.026 0-.55-.458-1.033-1.033-1.033h-.066C12.487 7 12 7.487 12 8.033c0 1.065-.27 2.055-.645 2.978-.405.926-.935 1.800-1.831 2.058-.667.19-1.222.066-1.666-.237a1.72 1.72 0 0 1-.704-1.066l-1.323-1.406 1.03-1.03c.524-.523.927-1.079.927-2.026 0-.55-.458-1.033-1.033-1.033h-.066c-.546 0-1.033.487-1.033 1.033 0 1.065-.27 2.055-.645 2.978-.405.926-.935 1.800-1.831 2.058-.667.19-1.222.066-1.666-.237a1.72 1.72 0 0 1-.704-1.066L1.97 8.28l1.03-1.03c.524-.523.927-1.079.927-2.026 0-.55-.458-1.033-1.033-1.033h-.066C1.487 4 1 4.487 1 5.033c0 1.065-.27 2.055-.645 2.978-.405.926-.935 1.800-1.831 2.058-.667.19-1.222.066-1.666-.237a1.72 1.72 0 0 1-.704-1.066L-2.03 7.28l1.03-1.03z"/>
  </svg>
);

const TargetIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
    <path d="M8 13A5 5 0 1 1 8 3a5 5 0 0 1 0 10zm0 1A6 6 0 1 0 8 2a6 6 0 0 0 0 12z"/>
    <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
    <path d="M9.5 8a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
  </svg>
);

const LoadingIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
    <path d="M11.534 7h3.26a.5.5 0 0 1 .488.608l-.494 2.01a.5.5 0 0 1-.488.392h-.495a.5.5 0 0 0-.488.41l-.578 2.924a.5.5 0 0 1-.488.408H.5a.5.5 0 0 1-.488-.408l-.578-2.924A.5.5 0 0 0 0 9.618h-.495a.5.5 0 0 1-.488-.391l-.494-2.01a.5.5 0 0 1 .488-.609h3.26a.5.5 0 0 0 .488-.409l.578-2.924a.5.5 0 0 1 .488-.408h6.252a.5.5 0 0 1 .488.408l.578 2.924a.5.5 0 0 0 .488.409zm-11.738 5.468A.5.5 0 0 0 .5 14h13a.5.5 0 0 0 .488-.532l-.494-2.01a.5.5 0 0 0-.488-.408H.5a.5.5 0 0 0-.488.408l-.494 2.01z"/>
  </svg>
);

interface PredictionData {
  date: string;
  confirmed_cases: number;
  predicted_cases: number;
}

interface CountryPrediction {
  country: string;
  current_cases: number;
  predicted_cases_30d: number;
  growth_rate: number;
  risk_score: string;
  predictions: PredictionData[];
}

interface HeatmapData {
  region: string;
  cases: number;
  deaths: number;
  risk_level: string;
}

interface HeatmapResponse {
  country: string;
  total_cases: number;
  total_deaths: number;
  data: HeatmapData[];
}

interface GlobalCountryData {
  country: string;
  current_cases: number;
  risk_level: string;
  growth_rate: number;
}

interface GlobalHeatmapResponse {
  total_countries: number;
  timestamp: string;
  countries: GlobalCountryData[];
}

function App() {
  const [country, setCountry] = useState<string>("India");
  const [countries, setCountries] = useState<string[]>([]);
  const [data, setData] = useState<CountryPrediction | null>(null);
  const [heatmapData, setHeatmapData] = useState<HeatmapResponse | null>(null);
  const [globalHeatmap, setGlobalHeatmap] = useState<GlobalHeatmapResponse | null>(null);
  const [loading, setLoading] = useState<boolean>(true);
  const [loadingGlobal, setLoadingGlobal] = useState<boolean>(true);
  const [error, setError] = useState<string | null>(null);

  // Fetch available countries
  useEffect(() => {
    const getCountries = async () => {
      try {
        const response = await fetch(`${API_BASE_URL}/countries`);
        if (!response.ok) throw new Error("Failed to fetch countries");
        const list = await response.json();
        setCountries(list);
        console.log("Countries loaded:", list);
      } catch (err) {
        console.error("Error loading countries:", err);
        setCountries(["India", "USA", "Brazil", "United Kingdom", "France", "Germany"]);
      }
    };
    getCountries();
  }, []);

  // Fetch prediction data for selected country
  useEffect(() => {
    const getPrediction = async () => {
      if (!country) return;
      setLoading(true);
      setError(null);
      try {
        const response = await fetch(`${API_BASE_URL}/predict/${country}`);
        if (!response.ok) throw new Error(`Failed to fetch predictions for ${country}`);
        const prediction = await response.json();
        // Format dates for better display
        const formattedPredictions = prediction.predictions.map((p: PredictionData) => ({
          ...p,
          date: new Date(p.date).toLocaleDateString("en-US", { month: "short", day: "numeric" }),
        }));
        setData({ ...prediction, predictions: formattedPredictions });
        console.log("Prediction loaded for", country);
      } catch (err) {
        console.error("Error loading predictions:", err);
        setError(`Failed to load predictions for ${country}`);
      } finally {
        setLoading(false);
      }
    };
    getPrediction();
  }, [country]);

  // Fetch heatmap data for India
  useEffect(() => {
    const getHeatmap = async () => {
      if (country !== "India") return;
      try {
        const response = await fetch(`${API_BASE_URL}/heatmap/${country}`, { method: "POST" });
        if (!response.ok) throw new Error("Failed to fetch heatmap");
        const heatmap = await response.json();
        setHeatmapData(heatmap);
        console.log("Heatmap loaded for India");
      } catch (err) {
        console.error("Error loading heatmap:", err);
      }
    };
    getHeatmap();
  }, [country]);

  // Fetch global heatmap data (all countries)
  useEffect(() => {
    const getGlobalHeatmap = async () => {
      setLoadingGlobal(true);
      try {
        const response = await fetch(`${API_BASE_URL}/global-heatmap`);
        if (!response.ok) throw new Error("Failed to fetch global heatmap");
        const globalData = await response.json();
        setGlobalHeatmap(globalData);
        console.log("Global heatmap loaded:", globalData.total_countries, "countries");
      } catch (err) {
        console.error("Error loading global heatmap:", err);
      } finally {
        setLoadingGlobal(false);
      }
    };
    getGlobalHeatmap();
  }, []);

  const getRiskColor = (level: string) => {
    if (level === "High") return "#FF6B6B";
    if (level === "Medium") return "#FFD700";
    return "#90EE90";
  };

  return (
    <div className="app-container" style={{ 
      minHeight: "100vh",
      background: "linear-gradient(135deg, #1a0e1e 0%, #2d1625 25%, #1a0e1e 50%, #2d1625 75%, #1a0e1e 100%)",
      backgroundAttachment: "fixed",
      position: "relative",
      overflow: "hidden"
    }}>
      {/* Virus Background overlay */}
      <div style={{
        position: "fixed",
        top: 0,
        left: 0,
        right: 0,
        bottom: 0,
        backgroundImage: `url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600"><defs><radialGradient id="v1" cx="30%" cy="30%"><stop offset="0%25" style="stop-color:rgba(255,182,193,0.08);stop-opacity:1" /><stop offset="100%25" style="stop-color:rgba(255,182,193,0);stop-opacity:1" /></radialGradient><radialGradient id="v2" cx="40%" cy="60%"><stop offset="0%25" style="stop-color:rgba(255,107,107,0.1);stop-opacity:1" /><stop offset="100%25" style="stop-color:rgba(255,107,107,0);stop-opacity:1" /></radialGradient></defs><circle cx="150" cy="100" r="80" fill="url(%23v1)" opacity="0.3"/><circle cx="600" cy="400" r="100" fill="url(%23v2)" opacity="0.2"/><circle cx="300" cy="500" r="60" fill="url(%23v1)" opacity="0.25"/></svg>')`,
        backgroundRepeat: "repeat",
        backgroundSize: "800px 600px",
        pointerEvents: "none",
        zIndex: 0
      }} />

      {/* Header */}
      <header className="app-header" style={{
        background: "linear-gradient(90deg, rgba(86,28,36,0.95) 0%, rgba(109,41,50,0.95) 50%, rgba(86,28,36,0.95) 100%)",
        backdropFilter: "blur(10px)",
        borderBottom: "2px solid rgba(199,183,163,0.2)",
        padding: "1.5rem 2rem",
        position: "sticky",
        top: 0,
        zIndex: 101,
        boxShadow: "0 8px 32px rgba(0,0,0,0.3)"
      }}>
        <div className="header-content" style={{ display: "flex", justifyContent: "space-between", alignItems: "center", maxWidth: "1400px", margin: "0 auto" }}>
          <div className="header-left">
            <h1 className="app-title" style={{
              fontSize: "32px",
              fontWeight: "800",
              background: "linear-gradient(135deg, #E8D8C4 0%, #FFB6C1 50%, #E8D8C4 100%)",
              WebkitBackgroundClip: "text",
              WebkitTextFillColor: "transparent",
              backgroundClip: "text",
              marginBottom: "0.25rem",
              display: "flex",
              alignItems: "center",
              gap: "0.75rem"
            }}>
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="url(#grad1)" viewBox="0 0 16 16">
                <defs><linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stopColor="#FFB6C1" /><stop offset="100%" stopColor="#E8D8C4" /></linearGradient></defs>
                <circle cx="8" cy="4" r="3" opacity="0.8"/>
                <circle cx="13" cy="8" r="2" opacity="0.7"/>
                <circle cx="3" cy="8" r="2" opacity="0.7"/>
                <circle cx="8" cy="12" r="2" opacity="0.7"/>
              </svg>
              EPIDEMIC SPREAD PREDICTION
            </h1>
            <p className="app-subtitle" style={{
              fontSize: "13px",
              color: "#C7B7A3",
              letterSpacing: "1.5px",
              fontWeight: "600"
            }}>REAL-TIME COVID-19 FORECASTING & RISK ASSESSMENT</p>
          </div>
          <div className="header-right" style={{ display: "flex", gap: "2rem" }}>
            <div className="global-stats" style={{ display: "flex", gap: "2rem" }}>
              <div className="stat" style={{
                background: "linear-gradient(135deg, rgba(109,41,50,0.6) 0%, rgba(199,183,163,0.1) 100%)",
                padding: "1rem 1.5rem",
                borderRadius: "8px",
                border: "1px solid rgba(199,183,163,0.2)",
                textAlign: "center",
                backdropFilter: "blur(10px)",
                display: "flex",
                alignItems: "center",
                gap: "0.75rem"
              }}>
                <GlobeIcon />
                <div>
                  <span className="stat-number" style={{ fontSize: "24px", fontWeight: "700", color: "#FFB6C1", display: "block" }}>{countries.length || "200+"}</span>
                  <span className="stat-label" style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "600", letterSpacing: "1px", display: "block", marginTop: "0.5rem" }}>COUNTRIES</span>
                </div>
              </div>
              <div className="stat" style={{
                background: "linear-gradient(135deg, rgba(109,41,50,0.6) 0%, rgba(199,183,163,0.1) 100%)",
                padding: "1rem 1.5rem",
                borderRadius: "8px",
                border: "1px solid rgba(199,183,163,0.2)",
                textAlign: "center",
                backdropFilter: "blur(10px)",
                display: "flex",
                alignItems: "center",
                gap: "0.75rem"
              }}>
                <div style={{ width: "16px", height: "16px", color: "#90EE90" }}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16z"/><circle cx="8" cy="8" r="2" fill="currentColor"/>
                  </svg>
                </div>
                <div>
                  <span className="stat-number" style={{ fontSize: "24px", fontWeight: "700", color: "#90EE90", display: "block" }}>LIVE</span>
                  <span className="stat-label" style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "600", letterSpacing: "1px", display: "block", marginTop: "0.5rem" }}>REAL-TIME</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="app-main" style={{ padding: "2rem", maxWidth: "1400px", margin: "0 auto", position: "relative", zIndex: 1 }}>
        {/* Sidebar */}
        <aside className="sidebar" style={{
          background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
          border: "1px solid rgba(199,183,163,0.2)",
          borderRadius: "12px",
          padding: "2rem",
          marginBottom: "2rem",
          backdropFilter: "blur(10px)",
          boxShadow: "0 8px 32px rgba(0,0,0,0.2)"
        }}>
          <label style={{ 
            display: "flex",
            alignItems: "center",
            gap: "0.5rem",
            fontSize: "12px", 
            fontWeight: "700", 
            marginBottom: "1rem", 
            color: "#FFB6C1",
            letterSpacing: "1.5px",
            textTransform: "uppercase"
          }}>
            <MapIcon />
            SELECT COUNTRY/REGION
          </label>
          <select
            value={country}
            onChange={(e) => setCountry(e.target.value)}
            style={{
              width: "100%",
              padding: "12px 16px",
              border: "2px solid rgba(199,183,163,0.3)",
              borderRadius: "8px",
              fontSize: "14px",
              fontWeight: "500",
              background: "rgba(26,14,30,0.6)",
              color: "#E8D8C4",
              cursor: "pointer",
              transition: "all 0.3s ease",
              backdropFilter: "blur(10px)"
            }}
            onFocus={(e) => {
              e.currentTarget.style.borderColor = "rgba(255,182,193,0.8)";
              e.currentTarget.style.boxShadow = "0 0 20px rgba(255,182,193,0.2)";
            }}
            onBlur={(e) => {
              e.currentTarget.style.borderColor = "rgba(199,183,163,0.3)";
              e.currentTarget.style.boxShadow = "none";
            }}
          >
            {countries.map((c) => (
              <option key={c} value={c} style={{ background: "#2d1625", color: "#E8D8C4" }}>
                {c}
              </option>
            ))}
          </select>
        </aside>

        {/* Dashboard */}
        <div className="dashboard" style={{ display: "grid", gap: "2rem" }}>
          {error && (
            <div style={{ 
              background: "linear-gradient(135deg, rgba(255,107,107,0.3) 0%, rgba(200,50,50,0.2) 100%)",
              color: "#FFB6C1", 
              padding: "1.5rem", 
              borderRadius: "10px",
              border: "1px solid rgba(255,107,107,0.4)",
              backdropFilter: "blur(10px)",
              display: "flex",
              alignItems: "center",
              gap: "1rem"
            }}>
              <AlertIcon />
              <span style={{ fontSize: "14px", fontWeight: "500" }}>{error}</span>
            </div>
          )}

          {loading ? (
            <div style={{ 
              textAlign: "center", 
              padding: "4rem 2rem", 
              color: "#C7B7A3",
              background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
              borderRadius: "12px",
              border: "1px solid rgba(199,183,163,0.2)",
              backdropFilter: "blur(10px)"
            }}>
              <div style={{ 
                display: "inline-block", 
                color: "#FFB6C1",
                fontSize: "32px",
                marginBottom: "1rem",
                animation: "spin 2s linear infinite"
              }}>
                <LoadingIcon />
              </div>
              <p style={{ fontSize: "16px", fontWeight: "500" }}>Loading data for <span style={{ color: "#FFB6C1", fontWeight: "700" }}>{country}...</span></p>
            </div>
          ) : data ? (
            <>
              {/* Risk Score Card */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "2rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase",
                  display: "flex",
                  alignItems: "center",
                  gap: "0.75rem"
                }}>
                  <HeartIcon />
                  RISK ASSESSMENT • {data.country.toUpperCase()}
                </h2>
                <div style={{ display: "grid", gridTemplateColumns: "auto 1fr", gap: "3rem", alignItems: "center" }}>
                  <div style={{ 
                    background: getRiskColor(data.risk_score), 
                    color: "white", 
                    padding: "2.5rem",
                    borderRadius: "12px",
                    textAlign: "center",
                    minWidth: "180px",
                    boxShadow: `0 0 30px ${getRiskColor(data.risk_score)}40`,
                    border: `2px solid ${getRiskColor(data.risk_score)}`
                  }}>
                    <div style={{ fontSize: "36px", fontWeight: "900", marginBottom: "0.5rem" }}>{data.risk_score}</div>
                    <div style={{ fontSize: "12px", fontWeight: "700", letterSpacing: "1px", opacity: 0.9 }}>THREAT LEVEL</div>
                  </div>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "1.5rem" }}>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "0.5rem" }}>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                          <path d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16z"/></svg>
                        CASES
                      </div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#E8D8C4" }}>{(data.current_cases / 1000000).toFixed(2)}M</div>
                    </div>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "0.5rem" }}>
                        <TrendUpIcon />
                        GROWTH
                      </div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#FFB6C1" }}>{data.growth_rate.toFixed(2)}%</div>
                    </div>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "0.5rem" }}>
                        <TargetIcon />
                        30-DAY
                      </div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#90EE90" }}>{(data.predicted_cases_30d / 1000000).toFixed(2)}M</div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Chart */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease 0.1s both"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "1.5rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase",
                  display: "flex",
                  alignItems: "center",
                  gap: "0.75rem"
                }}>
                  <ChartIcon />
                  30-DAY FORECAST: {data.country.toUpperCase()}
                </h2>
                <ResponsiveContainer width="100%" height={350}>
                  <AreaChart data={data.predictions}>
                    <defs>
                      <linearGradient id="colorPredicted" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="5%" stopColor="#FFB6C1" stopOpacity={0.8} />
                        <stop offset="95%" stopColor="#FFB6C1" stopOpacity={0.1} />
                      </linearGradient>
                    </defs>
                    <CartesianGrid strokeDasharray="3 3" stroke="rgba(199,183,163,0.1)" />
                    <XAxis dataKey="date" angle={-45} textAnchor="end" height={80} stroke="#C7B7A3" />
                    <YAxis stroke="#C7B7A3" />
                    <Tooltip 
                      formatter={(value: number) => [(value / 1000000).toFixed(2) + "M", "Cases"]}
                      contentStyle={{
                        background: "rgba(26,14,30,0.9)",
                        border: "1px solid rgba(199,183,163,0.3)",
                        borderRadius: "8px",
                        backdropFilter: "blur(10px)"
                      }}
                    />
                    <Area type="monotone" dataKey="predicted_cases" stroke="#FFB6C1" fill="url(#colorPredicted)" strokeWidth={3} />
                  </AreaChart>
                </ResponsiveContainer>
              </div>

              {/* Heatmap for India */}
              {country === "India" && heatmapData && (
                <div className="dashboard-section" style={{ 
                  background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                  padding: "2.5rem",
                  borderRadius: "16px",
                  border: "1px solid rgba(199,183,163,0.2)",
                  backdropFilter: "blur(10px)",
                  boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                  animation: "slideInUp 0.6s ease 0.2s both"
                }}>
                  <h2 style={{ 
                    color: "#FFB6C1", 
                    marginBottom: "1.5rem",
                    fontSize: "20px",
                    fontWeight: "700",
                    letterSpacing: "1px",
                    textTransform: "uppercase",
                    display: "flex",
                    alignItems: "center",
                    gap: "0.75rem"
                  }}>
                    <GlobeIcon />
                    INDIA STATE-WISE BREAKDOWN
                  </h2>
                  <div
                    style={{
                      display: "grid",
                      gridTemplateColumns: "repeat(auto-fit, minmax(140px, 1fr))",
                      gap: "1rem",
                      marginBottom: "1.5rem",
                    }}
                  >
                    {heatmapData.data.slice(0, 10).map((state, idx) => (
                      <div
                        key={state.region}
                        style={{
                          background: getRiskColor(state.risk_level),
                          color: "white",
                          padding: "1.5rem",
                          borderRadius: "10px",
                          textAlign: "center",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          boxShadow: `0 0 20px ${getRiskColor(state.risk_level)}40`,
                          border: `1px solid ${getRiskColor(state.risk_level)}`,
                          animation: `slideInUp 0.6s ease ${0.3 + idx * 0.05}s both`
                        }}
                        onMouseEnter={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "translateY(-5px)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 10px 30px ${getRiskColor(state.risk_level)}60`;
                        }}
                        onMouseLeave={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "translateY(0)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 0 20px ${getRiskColor(state.risk_level)}40`;
                        }}
                      >
                        <div style={{ fontWeight: "700", fontSize: "14px", marginBottom: "6px" }}>{state.region}</div>
                        <div style={{ fontSize: "12px", marginBottom: "4px", opacity: 0.9 }}>{(state.cases / 1000000).toFixed(1)}M</div>
                        <div style={{ fontSize: "11px", fontWeight: "700", opacity: 0.8 }}>{state.risk_level} RISK</div>
                      </div>
                    ))}
                  </div>
                  <div style={{ 
                    fontSize: "12px", 
                    color: "#C7B7A3",
                    padding: "1rem",
                    background: "rgba(255,255,255,0.03)",
                    borderRadius: "8px",
                    border: "1px solid rgba(199,183,163,0.1)"
                  }}>
                    📈 Total: {(heatmapData.total_cases / 1000000).toFixed(1)}M cases | Deaths: {(heatmapData.total_deaths / 1000000).toFixed(2)}M
                  </div>
                </div>
              )}

              {/* Global Countries Heatmap */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease 0.3s both"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "1.5rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase",
                  display: "flex",
                  alignItems: "center",
                  gap: "0.75rem"
                }}>
                  <GlobeIcon />
                  GLOBAL THREAT MAP (TOP 100 COUNTRIES)
                </h2>
                {loadingGlobal ? (
                  <div style={{ 
                    textAlign: "center", 
                    padding: "3rem", 
                    color: "#C7B7A3",
                    fontSize: "14px"
                  }}>
                    Scanning global data...
                  </div>
                ) : globalHeatmap ? (
                  <div
                    style={{
                      display: "grid",
                      gridTemplateColumns: "repeat(auto-fit, minmax(100px, 1fr))",
                      gap: "0.65rem",
                      marginBottom: "1.5rem",
                    }}
                  >
                    {globalHeatmap.countries.map((c, idx) => (
                      <div
                        key={c.country}
                        style={{
                          background: getRiskColor(c.risk_level),
                          color: "white",
                          padding: "0.9rem",
                          borderRadius: "8px",
                          textAlign: "center",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          boxShadow: `0 0 15px ${getRiskColor(c.risk_level)}30`,
                          border: `1px solid ${getRiskColor(c.risk_level)}`,
                          overflow: "hidden",
                          animation: `slideInUp 0.5s ease ${0.4 + idx * 0.01}s both`
                        }}
                        onMouseEnter={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "scale(1.08)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 5px 20px ${getRiskColor(c.risk_level)}80`;
                        }}
                        onMouseLeave={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "scale(1)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 0 15px ${getRiskColor(c.risk_level)}30`;
                        }}
                        onClick={() => setCountry(c.country)}
                        title={`${c.country}: ${(c.current_cases / 1000000).toFixed(1)}M cases`}
                      >
                        <div style={{ fontWeight: "700", fontSize: "11px", marginBottom: "3px" }}>{c.country}</div>
                        <div style={{ fontSize: "10px", fontWeight: "600" }}>{c.risk_level}</div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div style={{ textAlign: "center", padding: "2rem", color: "#C7B7A3" }}>
                    Failed to load
                  </div>
                )}
                <div style={{ 
                  fontSize: "12px", 
                  color: "#C7B7A3",
                  padding: "1rem",
                  background: "rgba(255,255,255,0.03)",
                  borderRadius: "8px",
                  border: "1px solid rgba(199,183,163,0.1)",
                  display: "flex",
                  alignItems: "center",
                  gap: "0.5rem"
                }}>
                  <TargetIcon />
                  {globalHeatmap?.total_countries || 0} countries monitored • Click any country for details
                </div>
              </div>
            </>
          ) : (
            <div style={{ 
              textAlign: "center", 
              padding: "4rem 2rem", 
              color: "#C7B7A3",
              background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
              borderRadius: "12px",
              border: "1px solid rgba(199,183,163,0.2)",
              backdropFilter: "blur(10px)"
            }}>
              <p style={{ fontSize: "16px" }}>No data available</p>
            </div>
          )}
        </div>
      </main>

      {/* Footer */}
      <footer className="app-footer" style={{
        background: "linear-gradient(90deg, rgba(86,28,36,0.9) 0%, rgba(109,41,50,0.9) 100%)",
        borderTop: "1px solid rgba(199,183,163,0.2)",
        padding: "2rem",
        marginTop: "4rem",
        textAlign: "center",
        color: "#C7B7A3",
        position: "relative",
        zIndex: 100
      }}>
        <p style={{ fontSize: "13px", fontWeight: "500", letterSpacing: "0.5px" }}>© 2026 EPIDEMIC SPREAD PREDICTION | AI-POWERED FORECASTING</p>
        <p style={{ marginTop: "0.5rem", opacity: 0.7, fontSize: "11px", fontWeight: "400" }}>Last updated: {new Date().toLocaleString()}</p>
      </footer>

      <style>{`
        @keyframes slideInUp {
          from {
            opacity: 0;
            transform: translateY(30px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
        
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.6; }
        }
        
        * {
          scrollbar-width: thin;
          scrollbar-color: rgba(199, 183, 163, 0.3) transparent;
        }
        
        *::-webkit-scrollbar {
          width: 8px;
        }
        
        *::-webkit-scrollbar-track {
          background: transparent;
        }
        
        *::-webkit-scrollbar-thumb {
          background: rgba(199, 183, 163, 0.3);
          border-radius: 4px;
        }
        
        *::-webkit-scrollbar-thumb:hover {
          background: rgba(199, 183, 163, 0.6);
        }
      `}</style>
    </div>
  );
      {/* Header */}
      <header className="app-header" style={{
        background: "linear-gradient(90deg, rgba(86,28,36,0.95) 0%, rgba(109,41,50,0.95) 50%, rgba(86,28,36,0.95) 100%)",
        backdropFilter: "blur(10px)",
        borderBottom: "2px solid rgba(199,183,163,0.2)",
        padding: "1.5rem 2rem",
        position: "sticky",
        top: 0,
        zIndex: 100,
        boxShadow: "0 8px 32px rgba(0,0,0,0.3)"
      }}>
        <div className="header-content" style={{ display: "flex", justifyContent: "space-between", alignItems: "center", maxWidth: "1400px", margin: "0 auto" }}>
          <div className="header-left">
            <h1 className="app-title" style={{
              fontSize: "32px",
              fontWeight: "800",
              background: "linear-gradient(135deg, #E8D8C4 0%, #FFB6C1 50%, #E8D8C4 100%)",
              WebkitBackgroundClip: "text",
              WebkitTextFillColor: "transparent",
              backgroundClip: "text",
              marginBottom: "0.25rem"
            }}>🦠 EPIDEMIC SPREAD PREDICTION</h1>
            <p className="app-subtitle" style={{
              fontSize: "13px",
              color: "#C7B7A3",
              letterSpacing: "1.5px",
              fontWeight: "600"
            }}>REAL-TIME COVID-19 FORECASTING & RISK ASSESSMENT</p>
          </div>
          <div className="header-right" style={{ display: "flex", gap: "2rem" }}>
            <div className="global-stats" style={{ display: "flex", gap: "2rem" }}>
              <div className="stat" style={{
                background: "linear-gradient(135deg, rgba(109,41,50,0.6) 0%, rgba(199,183,163,0.1) 100%)",
                padding: "1rem 1.5rem",
                borderRadius: "8px",
                border: "1px solid rgba(199,183,163,0.2)",
                textAlign: "center",
                backdropFilter: "blur(10px)"
              }}>
                <span className="stat-number" style={{ fontSize: "24px", fontWeight: "700", color: "#FFB6C1", display: "block" }}>{countries.length || "200+"}</span>
                <span className="stat-label" style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "600", letterSpacing: "1px", display: "block", marginTop: "0.5rem" }}>COUNTRIES</span>
              </div>
              <div className="stat" style={{
                background: "linear-gradient(135deg, rgba(109,41,50,0.6) 0%, rgba(199,183,163,0.1) 100%)",
                padding: "1rem 1.5rem",
                borderRadius: "8px",
                border: "1px solid rgba(199,183,163,0.2)",
                textAlign: "center",
                backdropFilter: "blur(10px)"
              }}>
                <span className="stat-number" style={{ fontSize: "24px", fontWeight: "700", color: "#90EE90", display: "block" }}>LIVE</span>
                <span className="stat-label" style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "600", letterSpacing: "1px", display: "block", marginTop: "0.5rem" }}>REAL-TIME</span>
              </div>
            </div>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="app-main" style={{ padding: "2rem", maxWidth: "1400px", margin: "0 auto" }}>
        {/* Sidebar */}
        <aside className="sidebar" style={{
          background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
          border: "1px solid rgba(199,183,163,0.2)",
          borderRadius: "12px",
          padding: "2rem",
          marginBottom: "2rem",
          backdropFilter: "blur(10px)",
          boxShadow: "0 8px 32px rgba(0,0,0,0.2)"
        }}>
          <label style={{ 
            display: "block", 
            fontSize: "12px", 
            fontWeight: "700", 
            marginBottom: "1rem", 
            color: "#FFB6C1",
            letterSpacing: "1.5px",
            textTransform: "uppercase"
          }}>
            📍 SELECT COUNTRY/REGION
          </label>
          <select
            value={country}
            onChange={(e) => setCountry(e.target.value)}
            style={{
              width: "100%",
              padding: "12px 16px",
              border: "2px solid rgba(199,183,163,0.3)",
              borderRadius: "8px",
              fontSize: "14px",
              fontWeight: "500",
              background: "rgba(26,14,30,0.6)",
              color: "#E8D8C4",
              cursor: "pointer",
              transition: "all 0.3s ease",
              backdropFilter: "blur(10px)"
            }}
            onFocus={(e) => {
              e.currentTarget.style.borderColor = "rgba(255,182,193,0.8)";
              e.currentTarget.style.boxShadow = "0 0 20px rgba(255,182,193,0.2)";
            }}
            onBlur={(e) => {
              e.currentTarget.style.borderColor = "rgba(199,183,163,0.3)";
              e.currentTarget.style.boxShadow = "none";
            }}
          >
            {countries.map((c) => (
              <option key={c} value={c} style={{ background: "#2d1625", color: "#E8D8C4" }}>
                {c}
              </option>
            ))}
          </select>
        </aside>

        {/* Dashboard */}
        <div className="dashboard" style={{ display: "grid", gap: "2rem" }}>
          {error && (
            <div style={{ 
              background: "linear-gradient(135deg, rgba(255,107,107,0.3) 0%, rgba(200,50,50,0.2) 100%)",
              color: "#FFB6C1", 
              padding: "1.5rem", 
              borderRadius: "10px",
              border: "1px solid rgba(255,107,107,0.4)",
              backdropFilter: "blur(10px)",
              display: "flex",
              alignItems: "center",
              gap: "1rem"
            }}>
              <span style={{ fontSize: "20px" }}>⚠️</span>
              <span style={{ fontSize: "14px", fontWeight: "500" }}>{error}</span>
            </div>
          )}

          {loading ? (
            <div style={{ 
              textAlign: "center", 
              padding: "4rem 2rem", 
              color: "#C7B7A3",
              background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
              borderRadius: "12px",
              border: "1px solid rgba(199,183,163,0.2)",
              backdropFilter: "blur(10px)"
            }}>
              <div style={{ 
                display: "inline-block", 
                color: "#FFB6C1",
                fontSize: "28px",
                marginBottom: "1rem",
                animation: "pulse 2s infinite"
              }}>⏳</div>
              <p style={{ fontSize: "16px", fontWeight: "500" }}>Loading data for <span style={{ color: "#FFB6C1", fontWeight: "700" }}>{country}...</span></p>
            </div>
          ) : data ? (
            <>
              {/* Risk Score Card */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "2rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase"
                }}>⚕️ RISK ASSESSMENT • {data.country.toUpperCase()}</h2>
                <div style={{ display: "grid", gridTemplateColumns: "auto 1fr", gap: "3rem", alignItems: "center" }}>
                  <div style={{ 
                    background: getRiskColor(data.risk_score), 
                    color: "white", 
                    padding: "2.5rem",
                    borderRadius: "12px",
                    textAlign: "center",
                    minWidth: "180px",
                    boxShadow: `0 0 30px ${getRiskColor(data.risk_score)}40`,
                    border: `2px solid ${getRiskColor(data.risk_score)}`
                  }}>
                    <div style={{ fontSize: "36px", fontWeight: "900", marginBottom: "0.5rem" }}>{data.risk_score}</div>
                    <div style={{ fontSize: "12px", fontWeight: "700", letterSpacing: "1px", opacity: 0.9 }}>THREAT LEVEL</div>
                  </div>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "1.5rem" }}>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase" }}>🦠 Cases</div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#E8D8C4" }}>{(data.current_cases / 1000000).toFixed(2)}M</div>
                    </div>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase" }}>📈 Growth</div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#FFB6C1" }}>{data.growth_rate.toFixed(2)}%</div>
                    </div>
                    <div style={{
                      background: "rgba(255,255,255,0.05)",
                      border: "1px solid rgba(199,183,163,0.2)",
                      borderRadius: "10px",
                      padding: "1.5rem",
                      backdropFilter: "blur(10px)"
                    }}>
                      <div style={{ fontSize: "11px", color: "#C7B7A3", fontWeight: "700", marginBottom: "0.5rem", letterSpacing: "1px", textTransform: "uppercase" }}>🔮 30-Day</div>
                      <div style={{ fontSize: "22px", fontWeight: "800", color: "#90EE90" }}>{(data.predicted_cases_30d / 1000000).toFixed(2)}M</div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Chart */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease 0.1s both"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "1.5rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase"
                }}>📊 30-DAY FORECAST: {data.country.toUpperCase()}</h2>
                <ResponsiveContainer width="100%" height={350}>
                  <AreaChart data={data.predictions}>
                    <defs>
                      <linearGradient id="colorPredicted" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="5%" stopColor="#FFB6C1" stopOpacity={0.8} />
                        <stop offset="95%" stopColor="#FFB6C1" stopOpacity={0.1} />
                      </linearGradient>
                    </defs>
                    <CartesianGrid strokeDasharray="3 3" stroke="rgba(199,183,163,0.1)" />
                    <XAxis dataKey="date" angle={-45} textAnchor="end" height={80} stroke="#C7B7A3" />
                    <YAxis stroke="#C7B7A3" />
                    <Tooltip 
                      formatter={(value: number) => [(value / 1000000).toFixed(2) + "M", "Cases"]}
                      contentStyle={{
                        background: "rgba(26,14,30,0.9)",
                        border: "1px solid rgba(199,183,163,0.3)",
                        borderRadius: "8px",
                        backdropFilter: "blur(10px)"
                      }}
                    />
                    <Area type="monotone" dataKey="predicted_cases" stroke="#FFB6C1" fill="url(#colorPredicted)" strokeWidth={3} />
                  </AreaChart>
                </ResponsiveContainer>
              </div>

              {/* Heatmap for India */}
              {country === "India" && heatmapData && (
                <div className="dashboard-section" style={{ 
                  background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                  padding: "2.5rem",
                  borderRadius: "16px",
                  border: "1px solid rgba(199,183,163,0.2)",
                  backdropFilter: "blur(10px)",
                  boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                  animation: "slideInUp 0.6s ease 0.2s both"
                }}>
                  <h2 style={{ 
                    color: "#FFB6C1", 
                    marginBottom: "1.5rem",
                    fontSize: "20px",
                    fontWeight: "700",
                    letterSpacing: "1px",
                    textTransform: "uppercase"
                  }}>🗺️ INDIA STATE-WISE BREAKDOWN</h2>
                  <div
                    style={{
                      display: "grid",
                      gridTemplateColumns: "repeat(auto-fit, minmax(140px, 1fr))",
                      gap: "1rem",
                      marginBottom: "1.5rem",
                    }}
                  >
                    {heatmapData.data.slice(0, 10).map((state, idx) => (
                      <div
                        key={state.region}
                        style={{
                          background: getRiskColor(state.risk_level),
                          color: "white",
                          padding: "1.5rem",
                          borderRadius: "10px",
                          textAlign: "center",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          boxShadow: `0 0 20px ${getRiskColor(state.risk_level)}40`,
                          border: `1px solid ${getRiskColor(state.risk_level)}`,
                          animation: `slideInUp 0.6s ease ${0.3 + idx * 0.05}s both`
                        }}
                        onMouseEnter={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "translateY(-5px)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 10px 30px ${getRiskColor(state.risk_level)}60`;
                        }}
                        onMouseLeave={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "translateY(0)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 0 20px ${getRiskColor(state.risk_level)}40`;
                        }}
                      >
                        <div style={{ fontWeight: "700", fontSize: "14px", marginBottom: "6px" }}>{state.region}</div>
                        <div style={{ fontSize: "12px", marginBottom: "4px", opacity: 0.9 }}>{(state.cases / 1000000).toFixed(1)}M</div>
                        <div style={{ fontSize: "11px", fontWeight: "700", opacity: 0.8 }}>{state.risk_level} RISK</div>
                      </div>
                    ))}
                  </div>
                  <div style={{ 
                    fontSize: "12px", 
                    color: "#C7B7A3",
                    padding: "1rem",
                    background: "rgba(255,255,255,0.03)",
                    borderRadius: "8px",
                    border: "1px solid rgba(199,183,163,0.1)"
                  }}>
                    📈 Total: {(heatmapData.total_cases / 1000000).toFixed(1)}M cases | Deaths: {(heatmapData.total_deaths / 1000000).toFixed(2)}M
                  </div>
                </div>
              )}

              {/* Global Countries Heatmap */}
              <div className="dashboard-section" style={{ 
                background: "linear-gradient(135deg, rgba(86,28,36,0.5) 0%, rgba(109,41,50,0.4) 100%)",
                padding: "2.5rem",
                borderRadius: "16px",
                border: "1px solid rgba(199,183,163,0.2)",
                backdropFilter: "blur(10px)",
                boxShadow: "0 8px 32px rgba(0,0,0,0.3)",
                animation: "slideInUp 0.6s ease 0.3s both"
              }}>
                <h2 style={{ 
                  color: "#FFB6C1", 
                  marginBottom: "1.5rem",
                  fontSize: "20px",
                  fontWeight: "700",
                  letterSpacing: "1px",
                  textTransform: "uppercase",
                  display: "flex",
                  alignItems: "center",
                  gap: "0.75rem"
                }}>
                  <GlobeIcon />
                  GLOBAL THREAT MAP (TOP 100 COUNTRIES)
                </h2>
                {loadingGlobal ? (
                  <div style={{ 
                    textAlign: "center", 
                    padding: "3rem", 
                    color: "#C7B7A3",
                    fontSize: "14px"
                  }}>
                    Scanning global data...
                  </div>
                ) : globalHeatmap ? (
                  <div
                    style={{
                      display: "grid",
                      gridTemplateColumns: "repeat(auto-fit, minmax(100px, 1fr))",
                      gap: "0.65rem",
                      marginBottom: "1.5rem",
                    }}
                  >
                    {globalHeatmap.countries.map((c, idx) => (
                      <div
                        key={c.country}
                        style={{
                          background: getRiskColor(c.risk_level),
                          color: "white",
                          padding: "0.9rem",
                          borderRadius: "8px",
                          textAlign: "center",
                          cursor: "pointer",
                          transition: "all 0.3s ease",
                          boxShadow: `0 0 15px ${getRiskColor(c.risk_level)}30`,
                          border: `1px solid ${getRiskColor(c.risk_level)}`,
                          overflow: "hidden",
                          animation: `slideInUp 0.5s ease ${0.4 + idx * 0.01}s both`
                        }}
                        onMouseEnter={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "scale(1.08)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 5px 20px ${getRiskColor(c.risk_level)}80`;
                        }}
                        onMouseLeave={(e) => {
                          (e.currentTarget as HTMLElement).style.transform = "scale(1)";
                          (e.currentTarget as HTMLElement).style.boxShadow = `0 0 15px ${getRiskColor(c.risk_level)}30`;
                        }}
                        onClick={() => setCountry(c.country)}
                        title={`${c.country}: ${(c.current_cases / 1000000).toFixed(1)}M cases`}
                      >
                        <div style={{ fontWeight: "700", fontSize: "11px", marginBottom: "3px" }}>{c.country}</div>
                        <div style={{ fontSize: "10px", fontWeight: "600" }}>{c.risk_level}</div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div style={{ textAlign: "center", padding: "2rem", color: "#C7B7A3" }}>
                    Failed to load
                  </div>
                )}
                <div style={{ 
                  fontSize: "12px", 
                  color: "#C7B7A3",
                  padding: "1rem",
                  background: "rgba(255,255,255,0.03)",
                  borderRadius: "8px",
                  border: "1px solid rgba(199,183,163,0.1)"
                }}>
                  🎯 {globalHeatmap?.total_countries || 0} countries monitored • Click any country for details
                </div>
              </div>
            </>
          ) : (
            <div style={{ 
              textAlign: "center", 
              padding: "4rem 2rem", 
              color: "#C7B7A3",
              background: "linear-gradient(135deg, rgba(86,28,36,0.4) 0%, rgba(109,41,50,0.3) 100%)",
              borderRadius: "12px",
              border: "1px solid rgba(199,183,163,0.2)",
              backdropFilter: "blur(10px)"
            }}>
              <p style={{ fontSize: "16px" }}>No data available</p>
            </div>
          )}
        </div>
      </main>

      {/* Footer */}
      <footer className="app-footer" style={{
        background: "linear-gradient(90deg, rgba(86,28,36,0.9) 0%, rgba(109,41,50,0.9) 100%)",
        borderTop: "1px solid rgba(199,183,163,0.2)",
        padding: "2rem",
        marginTop: "4rem",
        textAlign: "center",
        color: "#C7B7A3",
        position: "relative",
        zIndex: 100
      }}>
        <p style={{ fontSize: "13px", fontWeight: "500", letterSpacing: "0.5px" }}>© 2026 EPIDEMIC SPREAD PREDICTION | AI-POWERED FORECASTING</p>
        <p style={{ marginTop: "0.5rem", opacity: 0.7, fontSize: "11px", fontWeight: "400" }}>Last updated: {new Date().toLocaleString()}</p>
      </footer>

      <style>{`
        @keyframes slideInUp {
          from {
            opacity: 0;
            transform: translateY(30px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
        
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.6; }
        }
        
        * {
          scrollbar-width: thin;
          scrollbar-color: rgba(199, 183, 163, 0.3) transparent;
        }
        
        *::-webkit-scrollbar {
          width: 8px;
        }
        
        *::-webkit-scrollbar-track {
          background: transparent;
        }
        
        *::-webkit-scrollbar-thumb {
          background: rgba(199, 183, 163, 0.3);
          border-radius: 4px;
        }
        
        *::-webkit-scrollbar-thumb:hover {
          background: rgba(199, 183, 163, 0.6);
        }
      `}</style>
    </div>
  );
}

export default App;
